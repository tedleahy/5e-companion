{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
      "jsx": "react-jsx",
      "strict": true,
      "composite": true,
      "moduleSuffixes": [
          ".web",
          ".native",
          ""
      ],
      "paths": {
          "@/*": ["./*"]
      }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
