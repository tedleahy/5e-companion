{
    "name": "server",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "devDependencies": {
        "@graphql-codegen/cli": "^5.0.2",
        "@graphql-codegen/typescript": "^4.1.2",
        "@graphql-codegen/typescript-resolvers": "^4.3.1",
        "@types/bun": "latest",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@apollo/server": "^5.2.0",
        "@as-integrations/express5": "^1.1.2",
        "@graphql-tools/load-files": "^7.0.1",
        "@prisma/adapter-pg": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "cors": "^2.8.6",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "graphql": "^16.12.0",
        "jose": "^6.1.3",
        "prisma": "^7.3.0"
    },
    "scripts": {
        "dev": "bun --watch index.ts",
        "start": "bun run index.ts",
        "test": "bun test",
        "codegen": "bunx graphql-codegen --config codegen.yml",
        "prisma:generate": "bunx prisma generate",
        "db:deploy": "bunx prisma migrate deploy",
        "db:seed": "bunx prisma db seed",
        "reset-db": "bunx prisma migrate reset && bun run prisma:generate && bun run db:seed"
    }
}
